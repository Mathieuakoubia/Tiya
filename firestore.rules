rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /guardian_suggestions/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if true;
      allow delete: if true;
    }

    match /calendar_events/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if true;
      allow delete: if true;
    }

    match /calendar_connections_events/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if true;
      allow delete: if true;
    }

    match /calendar_connections/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if true;
      allow delete: if true;
    }

    match /Notification/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if true;
      allow delete: if true;
    }

    match /Squad/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if true;
      allow delete: if true;
    }

    match /squads/{squadId} {
      allow read: if request.auth != null;
      match /members/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /Actualite/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if true;
      allow delete: if true;
    }

    match /twin_signals/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if true;
      allow delete: if true;
    }

    match /GuardianActions/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if false;
      allow delete: if false;
    }

    match /CalendarEvents/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if false;
      allow delete: if false;
    }

    match /profil_twin/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow delete: if false;
    }

    match /routine/{parent}/taches/{document} {
      allow create: if request.auth != null;
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /{path=**}/taches/{document} {
      allow read: if true;
    }


    match /hume_jobs/{document} {
      allow create: if true;
      allow read: if true;
      allow write: if false;
      allow delete: if false;
    }

    match /challenge/{document} {
      allow create: if /databases/$(database)/documents/users/$(request.auth.uid) in request.resource.data.user;
      allow read: if /databases/$(database)/documents/users/$(request.auth.uid) in resource.data.user;
      allow write: if /databases/$(database)/documents/users/$(request.auth.uid) in resource.data.user;
      allow delete: if /databases/$(database)/documents/users/$(request.auth.uid) in resource.data.user;
    }

    match /users/{parent}/selfie/{document} {
      allow create: if request.auth.uid == parent;
      allow read: if true;
      allow write: if request.auth.uid == parent;
      allow delete: if request.auth.uid == parent;
    }

    match /{path=**}/selfie/{document} {
      allow read: if true;
    }


    match /routine/{document} {
      allow create: if request.resource.data.user_ref_path == /databases/$(database)/documents/users/$(request.auth.uid);
      allow read: if request.auth != null;
      allow write: if resource.data.user_ref_path == /databases/$(database)/documents/users/$(request.auth.uid);
      allow delete: if resource.data.user_ref_path == /databases/$(database)/documents/users/$(request.auth.uid);
    }

    match /users/{document} {
      allow create: if request.auth != null;
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if request.auth.token.email.matches("firebase@flutterflow.io");
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}